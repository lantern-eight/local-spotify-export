# COPY THIS FILE TO .env AND FILL IN THE VALUES.
# The .env file is ignored by git, this file is a template.

# Get these from https://developer.spotify.com/dashboard
# 1. Log in and click "Create App"
# 2. Set Redirect URI to: http://127.0.0.1:6820/callback
# 3. Copy Client ID and Client Secret here

SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1:6820/callback
